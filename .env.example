# .env.example — contrato de variables de entorno para el entorno local
#
# INSTRUCCIONES: copia este archivo como .env y rellena los valores reales.
# El .env NUNCA va al repositorio (está en .gitignore).
# En producción estos valores viven en AWS Secrets Manager,
# gestionados por Terraform. Aquí viven solo en tu máquina local.
#
# cp .env.example .env

# ── Backend ──────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# Google OAuth2 — obtenlos en console.cloud.google.com
GOOGLE_CLIENT_ID=tu-client-id-aqui
GOOGLE_CLIENT_SECRET=tu-client-secret-aqui
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback

# JWT — genera uno aleatorio: openssl rand -hex 32
JWT_SECRET=cambia-esto-por-un-secreto-real-en-local

